                else if 0x0446 < v then
                  if v == 0x0447 then some ("CYRILLIC SMALL LETTER CHE") else none
                else some ("CYRILLIC SMALL LETTER TSE")
              else some ("CYRILLIC SMALL LETTER EF")
            else some ("CYRILLIC SMALL LETTER ER")
          else some ("CYRILLIC SMALL LETTER I")
        else some ("CYRILLIC CAPITAL LETTER SHA")
      else some ("CYRILLIC CAPITAL LETTER JE")
    else some ("GREEK SMALL LETTER PSI")
  else some ("COMBINING DOUBLE OVERLINE")

end Unicode.TableLookupTables.Name.Chunk1
